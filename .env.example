# Pixel Agents Environment Variables
# Copy this file to .env and uncomment variables as needed.
# .env is gitignored and loaded automatically by the F5 launch config.

# Enable verbose debug logging for hook events (SessionStart, SessionEnd, Stop, etc.)
PIXEL_AGENTS_DEBUG=1

# OpenRouter API key for the openrouter-agent CLI.
# Alternatively, create ~/.pixel-agents/openrouter-config.json (recommended, chmod 600):
#   { "apiKey": "sk-or-v1-...", "model": "meta-llama/llama-4-maverick" }
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
